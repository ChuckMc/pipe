{
  "name": "pipe-cli",
  "version": "0.1.0",
  "description": "Pipe terminal output to AI — ask questions about any command output",
  "type": "module",
  "bin": {
    "pipe": "dist/index.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
